<% layout("/layouts/boilerplate.ejs")%>

    



<div class="container">
    <div class="row justify-content-center">

        <div style="border: none;" class=" show-card card col-lg-8 col-md-10 col-sm-12 " >
          <h4 class="card-title"><%=listing.title%></h4>
  <img style="
    height: 40rem; border-radius: 10px; object-fit: cover;" src="<%=listing.image.url%>" class="card-img-top "  alt="...">
  <div class="card-body">
    
    <h6 class="card-title">Owned by <%=listing.owner.username%></h6>
    <div><%=listing.description%></div>
    <p class="card-text">&#8377;<%=price%> Night</p>
    <div><%=listing.location%>,<%=listing.country%></div>
    <br>
    <%if(listing.geometry && listing.geometry.coordinates && listing.geometry.coordinates.length===2){%>
    <div class="mb-3">
      <h5>Where you'll be</h5>
      <div id="map" style="height:400px; border-radius:8px;"></div>
    </div>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const listingLat = <%= listing.geometry.coordinates[1] %>;
        const listingLng = <%= listing.geometry.coordinates[0] %>;
        const map = L.map('map').setView([listingLat, listingLng], 10);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
          maxZoom: 19
        }).addTo(map);

        L.marker([listingLat, listingLng]).addTo(map)
          .bindPopup("<%= listing.title %>")
          .openPopup();
      });
    </script>
    <%}%>
    <br>
    <%if(currUser && currUser._id.equals(listing.owner._id)){%>
      
    <div class="buttons">
      <a href="/listing/editForm/<%=listing._id%>" class="btn btn-danger">Edit</a>
    <form action="/listing/<%=listing._id%>?_method=DELETE" method="post">
      <button  class="mx-2 btn btn-danger" style="color: black;">Delete</button>
    </form>


    </div>
    <%}%>
    <hr>
    
  </div>
</div>



<div  class="col-lg-8 col-md-10 col-sm-12" >

<form class="needs-validation" novalidate  action="/listing/<%=listing._id%>/reviews" method="post" style="display: flex;
flex-direction: column;"> 
<div class="mb-3"><h3 >Leave a review</h3>
</div>
  <div class="mb-3">
    
<label for="rating" class="form-label">Rating</label>
    <fieldset class="starability-slot">
       
  
 
  <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="rating" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="rating" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="rating" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="rating" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="rating" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
  </div>
  
  <div class=" mb-3">
    <label for="comment" class="form-label">Comment</label>
     <textarea rows="5" name="comment" id="" class="form-control"></textarea>
     
    
  </div>
  <div class="mb-3">
    <button class="btn btn-outline-dark">Submit</button>
  </div>
  <hr>
 
 
</form>


<%if(currUser){%>
<div class="row">
  <h4>All Reviews</h4>
  <%for(let review of listing.reviews){%>
    
    <div class="card col-5 mx-2 my-2">
      <div class="card-body">
         <h5 class="card-title">@<%=review.author.username%></h5>
         
        
         <p class="starability-result" data-rating="<%=review.rating%>">
    Rated: 3 stars
  </p>
  <p class="card-text"><%=review.comment%></p>
        <form   action="/listing/<%=listing._id%>/reviews/<%=review._id%>?_method=delete" method="post">
          <button class="btn btn-small btn-outline-dark">Delete</button>
        </form>
      </div>
      
    </div>
    
 <% }%>
 </div>
 <%}%>
</div>

    </div>
</div>



